# ============ Recall — environment template ============
# Copy to `.env` and fill in secrets. NEVER commit `.env`.

# ---- Anthropic / Claude ----
ANTHROPIC_API_KEY=sk-ant-...
# Model tiering (see docs/adr/0002)
RECALL_MODEL_DEFAULT=claude-opus-4-8
RECALL_MODEL_BALANCED=claude-sonnet-4-6
RECALL_MODEL_CHEAP=claude-haiku-4-5

# ---- Elasticsearch ----
ES_HOST=http://localhost:9200
ES_INDEX=recall-docs
# bge-m3 embedding dimension
EMBEDDING_DIM=1024

# ---- Embedding sidecar ----
EMBEDDING_SERVICE_URL=http://localhost:8000
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
SEMANTIC_CACHE_THRESHOLD=0.95

# ---- PostgreSQL ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=recall
POSTGRES_USER=recall
POSTGRES_PASSWORD=recall

# ---- Kafka ----
# Host (gradle bootRun) reaches Kafka via the EXTERNAL listener on 29092.
# In-compose services use kafka:9092 (set in docker-compose.yml).
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_INGESTION_TOPIC=recall.ingestion

# ---- MinIO / S3 ----
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=recall-raw

# ---- Backend ----
SERVER_PORT=8080
