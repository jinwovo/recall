# ============ Recall — environment template ============
# Copy to `.env` and fill in secrets. NEVER commit `.env`.

# ---- Anthropic / Claude ----
ANTHROPIC_API_KEY=sk-ant-...
# Model tiering (see docs/adr/0002)
RECALL_MODEL_DEFAULT=claude-opus-4-8
RECALL_MODEL_BALANCED=claude-sonnet-4-6
RECALL_MODEL_CHEAP=claude-haiku-4-5

# ---- Elasticsearch ----
ES_HOST=http://localhost:9200
ES_INDEX=recall-docs
# bge-m3 embedding dimension
EMBEDDING_DIM=1024

# ---- Embedding sidecar ----
EMBEDDING_SERVICE_URL=http://localhost:8000
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
SEMANTIC_CACHE_THRESHOLD=0.95

# ---- PostgreSQL ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=recall
POSTGRES_USER=recall
POSTGRES_PASSWORD=recall

# ---- Kafka ----
# Host (gradle bootRun) reaches Kafka via the EXTERNAL listener on 29092.
# In-compose services use kafka:9092 (set in docker-compose.yml).
KAFKA_BOOTSTRAP_SERVERS=localhost:29092
KAFKA_INGESTION_TOPIC=recall.ingestion
# Ingestion failure policy (docs/adr/0005): bounded exponential retries, then dead-letter.
KAFKA_INGESTION_DLQ_TOPIC=recall.ingestion.dlq
KAFKA_RETRY_MAX_ATTEMPTS=3
KAFKA_RETRY_BACKOFF_MS=1000

# ---- MinIO / S3 ----
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=recall-raw
# Docs above this size travel through Kafka as an objectKey reference (claim check, adr/0005).
INGEST_INLINE_MAX_BYTES=65536

# ---- LLM provider toggle: claude (default) | groq | ollama (local, free) ----
LLM_PROVIDER=claude
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5-coder:3b

# ---- RAG guardrails (docs/adr/0004) ----
# Post-hoc groundedness judge — fail-open; runs on the CHEAP model tier.
RAG_JUDGE_ENABLED=true
RAG_JUDGE_TIMEOUT_SECONDS=45

# ---- Backend ----
SERVER_PORT=8080
