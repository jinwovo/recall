{
  "uid": "recall-overview",
  "title": "Recall — Overview",
  "tags": ["recall"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "LLM tokens/sec by model & type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (model, type) (rate(recall_llm_tokens_total[5m]))",
          "legendFormat": "{{model}} / {{type}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Semantic cache hits/sec",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(recall_semantic_cache_hits_total[5m])",
          "legendFormat": "cache hits"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Retrieval latency p95 by mode",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, mode) (rate(recall_retrieval_latency_seconds_bucket[5m])))",
          "legendFormat": "{{mode}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Ingestion throughput (docs & chunks/sec)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(recall_ingestion_docs_total[5m])",
          "legendFormat": "docs"
        },
        {
          "refId": "B",
          "expr": "rate(recall_ingestion_chunks_total[5m])",
          "legendFormat": "chunks"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "HTTP p95 latency",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 16 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum by (le, uri) (rate(http_server_requests_seconds_bucket[5m])))",
          "legendFormat": "{{uri}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Groundedness verdicts/sec (LLM judge)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (verdict) (rate(recall_rag_judge_verdicts_total[5m]))",
          "legendFormat": "{{verdict}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "stat",
      "title": "Groundedness (avg judge score, 1h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(recall_rag_groundedness_sum[1h])) / sum(increase(recall_rag_groundedness_count[1h]))",
          "legendFormat": "groundedness"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Ingestion reliability (retries / DLQ / raw-archive failures)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 32 },
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(recall_ingestion_retries_total[5m])",
          "legendFormat": "retries"
        },
        {
          "refId": "B",
          "expr": "rate(recall_ingestion_dlq_total[5m])",
          "legendFormat": "dead-lettered"
        },
        {
          "refId": "C",
          "expr": "rate(recall_ingestion_raw_store_failures_total[5m])",
          "legendFormat": "raw-archive failures (degraded to inline)"
        },
        {
          "refId": "D",
          "expr": "rate(recall_ingestion_dlq_publish_failures_total[5m])",
          "legendFormat": "DLQ publish failures"
        }
      ]
    }
  ]
}
